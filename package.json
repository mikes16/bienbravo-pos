{
  "name": "bien-bravo-pos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit",
    "sync-schema": "node scripts/sync-schema.mjs",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch"
  },
  "size-limit": [
    { "name": "Bundle inicial JS (brotli)", "path": "dist/assets/main-*.js", "limit": "105 kB" },
    { "name": "Apollo vendor (brotli)", "path": "dist/assets/vendor-apollo-*.js", "limit": "60 kB" },
    { "name": "Router vendor (brotli)", "path": "dist/assets/vendor-router-*.js", "limit": "36 kB" },
    { "name": "CSS de la app (brotli)", "path": "dist/assets/index-*.css", "limit": "16 kB" }
  ],
  "dependencies": {
    "@apollo/client": "^4.1.5",
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16.12.0",
    "graphql-ws": "^6.0.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/client-preset": "^4.8.3",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "size-limit": "^12.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
